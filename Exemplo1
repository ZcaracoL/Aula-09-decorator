from abc import ABC, abstractmethod

# Componente
class Bebida(ABC):
    @abstractmethod
    def custo(self):  # aqui eu to criando um método obrigatório, toda bebida vai ter que ter um custo
        pass          # não faz nada ainda, é só porque quem herda essa classe que vai implementar de verdade

    @abstractmethod
    def descricao(self):
        pass


# Componente Concreto
class CafeSimples(Bebida):
    def custo(self):
        return 5.0  # esse é o preço base do café simples, sem nenhum adicional

    def descricao(self):
        return "Café Simples"


# Decorator
class DecoradorBebida(Bebida):
    def __init__(self, bebida):
        self._bebida = bebida  # aqui eu guardo a bebida que veio antes pra conseguir ir adicionando coisas nela depois


# Decoradores Concretos
class Leite(DecoradorBebida):
    def custo(self):
        return self._bebida.custo() + 2.0

    def descricao(self):
        return self._bebida.descricao() + ", Leite"


class Chocolate(DecoradorBebida):
    def custo(self):
        return self._bebida.custo() + 3.0

    def descricao(self):
        return self._bebida.descricao() + ", Chocolate"


# Utilização
bebida = CafeSimples()
bebida = Leite(bebida)
bebida = Chocolate(bebida)

print("Descrição:", bebida.descricao())
print("Custo: R$", bebida.custo())
